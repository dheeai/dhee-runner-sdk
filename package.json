{
  "name": "@dheeai/runner-sdk",
  "version": "0.1.1",
  "description": "Authoring SDK for Dhee runners & bundles \u2014 the firewall a runner depends on.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dheeai/dhee-runner-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dheeai/dhee-runner-sdk.git"
  },
  "keywords": [
    "dhee",
    "dhee-runner",
    "sdk",
    "runner",
    "bundle"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}
